{
  "manifest_version": 3,
  "name": "Property Scout",
  "version": "1.0",
  "description": "Scan open property listing tabs and add them to Property Scout.",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://www.domain.com.au/*",
    "https://www.realestate.com.au/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Property Scout"
  }
}
